{
  "name": "factfast",
  "version": "1.0.0",
  "private": true,
  "description": "SaaS ERP/POS de Facturación Electrónica para Ecuador",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @factfast/api run start:dev",
    "dev:web": "pnpm --filter @factfast/web run dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter @factfast/api run build",
    "build:web": "pnpm --filter @factfast/web run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @factfast/api exec prisma generate",
    "db:migrate": "pnpm --filter @factfast/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @factfast/api exec prisma studio",
    "db:seed": "pnpm --filter @factfast/api exec prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
