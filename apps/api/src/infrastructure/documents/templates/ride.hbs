<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>RIDE - {{documento_titulo}}</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 10px;
            color: #111;
            margin: 0;
            padding: 0;
        }
        .container { width: 100%; padding: 10px 15px; }
        .header { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .header-left { width: 48%; display: flex; flex-direction: column; }
        .header-right { width: 49%; }
        .box { border: 1px solid #000; border-radius: 6px; padding: 8px 12px; }
        .logo-container {
            height: 105px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 10px;
        }
        .logo-placeholder {
            border: 1px dashed #999;
            width: 80%;
            height: 90%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            font-size: 18px;
            font-weight: bold;
        }
        .text-bold { font-weight: bold; }
        .text-right { text-align: right; }
        .info-row { margin-bottom: 4px; line-height: 1.3; }
        .info-label { font-weight: bold; margin-right: 4px; }
        .doc-title { font-size: 18px; font-weight: bold; letter-spacing: 1px; margin: 5px 0; }
        .ruc-title { font-size: 14px; font-weight: bold; }
        .auth-number { font-size: 11px; font-weight: bold; word-wrap: break-word; }
        .barcode-box { text-align: center; margin-top: 10px; }
        .barcode-box img { width: 100%; height: 45px; }
        .grid {
            display: grid;
            grid-template-columns: max-content 1fr max-content 1fr;
            gap: 4px 15px;
            align-items: center;
        }
        .section { margin-bottom: 10px; }
        .section-title {
            font-weight: bold;
            background: #eaeaea;
            border: 1px solid #000;
            border-bottom: 0;
            padding: 5px 6px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 9px;
        }
        th, td { border: 1px solid #000; padding: 5px 6px; vertical-align: top; }
        th { background-color: #eaeaea; font-weight: bold; text-align: left; }
        td.num, th.num { text-align: right; }
        .footer { display: flex; justify-content: space-between; gap: 12px; }
        .footer-left { width: 62%; }
        .footer-right { width: 35%; }
        .additional-box { border: 1px solid #000; padding: 8px; margin-bottom: 8px; }
        .additional-title { font-weight: bold; margin-bottom: 6px; }
        .totals-table tr.total th, .totals-table tr.total td {
            font-weight: bold;
            background-color: #eaeaea;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-left">
                <div class="logo-container">
                    <div class="logo-placeholder">LOGOTIPO</div>
                </div>
                <div class="box" style="flex-grow: 1;">
                    <div class="info-row text-bold" style="font-size: 13px; margin-bottom: 8px;">{{empresa.razon_social}}</div>
                    {{#if empresa.nombre_comercial}}
                    <div class="info-row"><span class="info-label">Nombre Comercial:</span> {{empresa.nombre_comercial}}</div>
                    {{/if}}
                    <div class="info-row"><span class="info-label">Dirección Matriz:</span> {{empresa.direccion_matriz}}</div>
                    <div class="info-row"><span class="info-label">Dirección Sucursal:</span> {{punto_emision.sucursal.direccion}}</div>
                    {{#if empresa.numero_resolucion}}
                    <div class="info-row"><span class="info-label">Contribuyente Especial Nro:</span> {{empresa.numero_resolucion}}</div>
                    {{/if}}
                    <div class="info-row"><span class="info-label">OBLIGADO A LLEVAR CONTABILIDAD:</span> {{#if empresa.obligado_contabilidad}}SI{{else}}NO{{/if}}</div>
                </div>
            </div>

            <div class="header-right box">
                <div class="ruc-title">R.U.C.: {{empresa.ruc}}</div>
                <div class="doc-title">{{documento_titulo}}</div>
                <div class="info-row" style="font-size: 13px;"><span class="info-label">No.</span> {{serie}}-{{numero_secuencial}}</div>

                <br>
                <div class="info-row info-label">NÚMERO DE AUTORIZACIÓN</div>
                <div class="info-row auth-number">{{numero_autorizacion}}</div>

                <br>
                <div class="info-row"><span class="info-label">FECHA Y HORA DE AUTORIZACIÓN:</span> {{fecha_autorizacion_str}}</div>
                <div class="info-row"><span class="info-label">AMBIENTE:</span> {{ambiente_sri}}</div>
                <div class="info-row"><span class="info-label">EMISIÓN:</span> NORMAL</div>

                <div class="barcode-box">
                    <div class="info-label" style="text-align: left; margin-bottom: 2px;">CLAVE DE ACCESO</div>
                    <img src="{{barcodeBase64}}" />
                    <div style="font-size: 10px; margin-top: 2px;">{{clave_acceso}}</div>
                </div>
            </div>
        </div>

        <div class="box section">
            <div class="grid">
                <div class="info-label">{{#if es_retencion}}Razón Social Sujeto Retenido:{{else}}{{#if es_guia_remision}}Razón Social Transportista:{{else}}Razón Social / Nombres y Apellidos:{{/if}}{{/if}}</div>
                <div>{{razon_social_comprador}}</div>
                <div class="info-label">Identificación:</div>
                <div>{{identificacion_comprador}}</div>
                <div class="info-label">Fecha Emisión:</div>
                <div>{{fecha_emision_str}}</div>
                {{#if direccion_comprador}}
                <div class="info-label">Dirección:</div>
                <div>{{direccion_comprador}}</div>
                {{/if}}
            </div>
        </div>

        {{#if info_especifica.length}}
        <div class="section">
            <div class="section-title">Información del comprobante</div>
            <table>
                <tbody>
                    {{#each info_especifica}}
                    <tr>
                        <th style="width: 28%;">{{this.etiqueta}}</th>
                        <td>{{this.valor}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/if}}

        <div class="section">
            <div class="section-title">Detalle</div>
            <table>
                <thead>
                    <tr>
                        {{#each tabla_principal.headers}}
                        <th>{{this}}</th>
                        {{/each}}
                    </tr>
                </thead>
                <tbody>
                    {{#each tabla_principal.rows}}
                    <tr>
                        {{#each this}}
                        <td>{{this}}</td>
                        {{/each}}
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <div class="footer">
            <div class="footer-left">
                <div class="additional-box">
                    <div class="additional-title">Información Adicional</div>
                    {{#if correo_comprador}}
                    <div class="info-row"><span class="info-label">Email:</span> {{correo_comprador}}</div>
                    {{/if}}
                    {{#each campos_adicionales}}
                    <div class="info-row"><span class="info-label">{{this.nombre}}:</span> {{this.valor}}</div>
                    {{/each}}
                </div>

                {{#if formas_pago.length}}
                <table>
                    <thead>
                        <tr>
                            <th>Forma de Pago</th>
                            <th class="num" style="width: 30%;">Valor</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each formas_pago}}
                        <tr>
                            <td>{{this.forma_pago}}</td>
                            <td class="num text-bold">{{this.total_fmt}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                {{/if}}
            </div>

            <div class="footer-right">
                {{#if totales_especificos.length}}
                <table class="totals-table">
                    <tbody>
                        {{#each totales_especificos}}
                        <tr class="{{#if @last}}total{{/if}}">
                            <th>{{this.etiqueta}}</th>
                            <td class="num">{{this.valor}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                {{/if}}
            </div>
        </div>
    </div>
</body>
</html>
