# ─── Aplicación ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# ─── Base de Datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=facturacion
DB_PASSWORD=facturacion_pass
DB_NAME=facturacion_db
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# ─── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass

# ─── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_muy_largo_access
JWT_REFRESH_SECRET=cambia_esto_por_un_secreto_muy_largo_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Criptografía AES-256 (para certificados .p12) ─────────────
# Debe ser exactamente 32 caracteres / 64 hex chars
MASTER_ENCRYPTION_KEY=cambia_esto_32_caracteres_exactos_ok

# ─── MinIO / S3 ────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=facturacion

# ─── SRI ───────────────────────────────────────────────────────
# pruebas | produccion
SRI_ENVIRONMENT=pruebas
SRI_WSDL_RECEIVE_TEST=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_WSDL_AUTHORIZE_TEST=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl
SRI_WSDL_RECEIVE_PROD=https://cel.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_WSDL_AUTHORIZE_PROD=https://cel.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl

# ─── Correo SMTP ───────────────────────────────────────────────
# Si no se configura SMTP_HOST y SMTP_FROM, la API genera el PDF pero omite el envio de correo.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Facturacion <no-reply@empresa.com>"
